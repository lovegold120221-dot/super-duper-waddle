# LLM Provider: "ollama" or "gemini"
LLM_PROVIDER=ollama

# Ollama (local LLM)
OLLAMA_MODEL=qwen3:8b

# Gemini (cloud LLM) - Only set if using gemini
# GEMINI_API_KEY=your_gemini_api_key_here

# Deepgram (Voice)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
